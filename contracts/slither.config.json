{
  "filter_paths": "lib/|test/|script/|node_modules/",
  "exclude_informational": true,
  "exclude_low": true,
  "exclude_optimization": true,
  "disable_color": true,
  "solc_remaps": [
    "@openzeppelin/=lib/openzeppelin-contracts/",
    "forge-std/=lib/forge-std/src/"
  ],
  "solc_args": "--optimize --optimize-runs 200"
}
