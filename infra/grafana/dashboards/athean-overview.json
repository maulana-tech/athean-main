          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "LLM cost (24h, USD)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "sum(increase(athean_llm_cost_usd_total[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Council diversity",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "fieldConfig": {"defaults": {"min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "orange", "value": 0.35}, {"color": "green", "value": 0.6}]}}},
      "targets": [{"expr": "athean_council_diversity", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Deliberation latency p95",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(athean_deliberation_duration_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM calls by provider",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(athean_llm_calls_total[5m])) by (provider)",
          "refId": "A",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Paper equity (USDC)",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [{"expr": "athean_paper_equity_usdc", "refId": "A"}]
